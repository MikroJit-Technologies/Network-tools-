#!/usr/bin/env sh
set -eu

VERSION="0.4.0"
OS_NAME="$(uname -s)"

log() {
  printf '%s\n' "$*"
}

section() {
  log ""
  log "==> $*"
}

warn() {
  printf 'warning: %s\n' "$*" >&2
}

has() {
  command -v "$1" >/dev/null 2>&1
}

run_if() {
  cmd="$1"
  shift

  if has "$cmd"; then
    "$cmd" "$@"
  else
    printf 'missing command: %s\n' "$cmd" >&2
    return 127
  fi
}

quiet_run() {
  "$@" 2>/dev/null || true
}

usage() {
  cat <<'EOF'
Usage: nt <command> [args]

Commands:
  doctor                 Show installed and missing network tools
  quick                  Run a short connectivity and local-network check
  tools                  Show tool inventory grouped by purpose
  summary                Show a compact network overview
  interfaces             Show interface addresses and link state
  routes                 Show routes
  dns [host]             Show DNS status and query a host
  http [url]             Show HTTP headers and timing
  tls <host> [port]      Show TLS certificate summary
  whois <target>         Run whois or RDAP lookup
  ping [host]            Ping a host, default 1.1.1.1
  trace [host]           Trace route to a host, default 1.1.1.1
  ports                  Show listening TCP/UDP ports
  scan <target>          Run a fast nmap scan
  capture [iface] [file] Capture packets with tcpdump
  wifi                   Show Wi-Fi device and network status
  monitor [seconds]      Refresh network overview
  export [file]          Write a diagnostic report
  path                   Show installed nt path and config paths
  fix                    Clear stale aliases and reload shell integration
  selftest               Run nt smoke tests
  vpn                    Show VPN/tunnel status
  firewall               Show firewall status
  speed                  Run speedtest if available
  myip                   Show public IP address
  help                   Show this help
EOF
}

doctor() {
  section "System"
  printf 'os      %s\n' "$OS_NAME"

  section "Core"
  for cmd in ping curl openssl; do
    if has "$cmd"; then
      printf 'ok      %s\n' "$cmd"
    else
      printf 'missing %s\n' "$cmd"
    fi
  done

  section "Recommended"
  case "$OS_NAME" in
    Darwin)
      recommended='ifconfig netstat lsof traceroute mtr dig nslookup host whois wget nc nmap tcpdump wireshark networksetup pfctl ssh rsync tailscale wg openvpn'
      ;;
    Linux)
      recommended='ip ifconfig ss netstat lsof traceroute tracepath mtr dig nslookup host whois wget nc nmap tcpdump tshark wireshark ethtool iw nmcli resolvectl nft ufw ssh rsync tailscale wg openvpn'
      ;;
    *)
      recommended='ifconfig netstat lsof traceroute mtr dig nslookup host whois wget nc nmap tcpdump ssh rsync'
      ;;
  esac

  for cmd in $recommended; do
    if has "$cmd"; then
      printf 'ok      %-14s %s\n' "$cmd" "$(command -v "$cmd")"
    else
      printf 'missing %s\n' "$cmd"
    fi
  done
  unset recommended
}

print_tool_group() {
  label="$1"
  shift

  section "$label"
  for cmd in "$@"; do
    if has "$cmd"; then
      printf 'ok      %-14s %s\n' "$cmd" "$(command -v "$cmd")"
    else
      printf 'missing %s\n' "$cmd"
    fi
  done
}

tools() {
  print_tool_group "Basics" ip ifconfig ss netstat lsof ping curl wget nc
  print_tool_group "DNS and HTTP" dig nslookup host whois openssl
  print_tool_group "Trace and scan" traceroute tracepath mtr nmap
  print_tool_group "Capture" tcpdump tshark wireshark
  if [ "$OS_NAME" = "Darwin" ]; then
    print_tool_group "Wi-Fi and device" networksetup
    print_tool_group "Firewall" pfctl
  else
    print_tool_group "Wi-Fi and device" ethtool iw nmcli
    print_tool_group "Firewall" nft ufw iptables
  fi
  print_tool_group "VPN and remote" tailscale wg openvpn ssh scp sftp rsync
}

quick() {
  section "Local command"
  command -v nt || true
  printf 'version %s\n' "$VERSION"

  section "Interfaces"
  if [ "$OS_NAME" = "Darwin" ]; then
    ifconfig | sed -n '1,40p'
  elif has ip; then
    quiet_run ip -brief address
  fi

  section "Default route"
  if [ "$OS_NAME" = "Darwin" ]; then
    netstat -rn 2>/dev/null | sed -n '1,20p' || true
  elif has ip; then
    quiet_run ip route show default
  fi

  section "DNS"
  dns "${1:-github.com}" || true

  section "Public IP"
  myip || true
}

summary() {
  section "Interfaces"
  if [ "$OS_NAME" = "Darwin" ]; then
    quiet_run ifconfig
  elif has ip; then
    quiet_run ip -brief address
  else
    run_if ifconfig || true
  fi

  section "Routes"
  if [ "$OS_NAME" = "Darwin" ]; then
    quiet_run netstat -rn
  elif has ip; then
    quiet_run ip route
  else
    run_if route -n || true
  fi

  section "DNS"
  if has resolvectl; then
    resolvectl status 2>/dev/null | sed -n '1,80p' || true
  elif [ -f /etc/resolv.conf ]; then
    sed -n '1,40p' /etc/resolv.conf
  fi

  section "Public IP"
  myip || true

  section "Listening ports"
  ports || true
}

interfaces() {
  if [ "$OS_NAME" = "Darwin" ]; then
    run_if ifconfig
  elif has ip; then
    run_if ip -brief address
  else
    run_if ifconfig
  fi

  section "Links"
  if has ip; then
    run_if ip -brief link
  fi
}

routes() {
  if [ "$OS_NAME" = "Darwin" ]; then
    run_if netstat -rn
  elif has ip; then
    run_if ip route
  else
    run_if route -n
  fi

  section "Rules"
  if has ip; then
    ip rule 2>/dev/null || true
  fi
}

dns() {
  host="${1:-github.com}"

  if has resolvectl; then
    section "Resolver"
    resolvectl status 2>/dev/null | sed -n '1,80p' || true
  fi

  section "Query $host"
  if has dig; then
    dig +short "$host"
  elif has host; then
    host "$host"
  else
    run_if nslookup "$host"
  fi
}

http() {
  url="${1:-https://github.com}"

  if ! has curl; then
    printf 'missing command: curl\n' >&2
    return 127
  fi

  if ! curl -L -o /dev/null -sS -D - \
    -w '\nlookup=%{time_namelookup}s connect=%{time_connect}s tls=%{time_appconnect}s first_byte=%{time_starttransfer}s total=%{time_total}s status=%{http_code}\n' \
    "$url"; then
    warn "HTTP check failed for $url"
    return 1
  fi
}

tls() {
  host="${1:-}"
  port="${2:-443}"

  if [ -z "$host" ]; then
    printf 'usage: nt tls <host> [port]\n' >&2
    return 2
  fi

  if ! has openssl; then
    printf 'missing command: openssl\n' >&2
    return 127
  fi

  printf '' | openssl s_client -servername "$host" -connect "$host:$port" 2>/dev/null |
    openssl x509 -noout -subject -issuer -dates -fingerprint -sha256
}

whois_lookup() {
  target="${1:-}"

  if [ -z "$target" ]; then
    printf 'usage: nt whois <target>\n' >&2
    return 2
  fi

  if has whois; then
    whois "$target"
  elif has curl; then
    curl -fsS "https://rdap.org/domain/$target" || curl -fsS "https://rdap.org/ip/$target"
    printf '\n'
  else
    printf 'missing command: whois or curl\n' >&2
    return 127
  fi
}

ping_host() {
  host="${1:-1.1.1.1}"
  run_if ping -c 4 "$host"
}

trace_host() {
  host="${1:-1.1.1.1}"

  if has mtr; then
    mtr -rwzc 5 "$host"
  elif has traceroute; then
    traceroute "$host"
  else
    run_if tracepath "$host"
  fi
}

ports() {
  if [ "$OS_NAME" = "Darwin" ] && has lsof; then
    lsof -nP -iTCP -sTCP:LISTEN
  elif has ss; then
    ss -tulpn 2>/dev/null || ss -tuln
  else
    run_if netstat -tulpn
  fi
}

wifi() {
  section "Wi-Fi devices"
  if [ "$OS_NAME" = "Darwin" ] && has networksetup; then
    networksetup -listallhardwareports | sed -n '/Wi-Fi/,+2p'
  elif has iw; then
    iw dev || true
  else
    log "iw not installed"
  fi

  section "NetworkManager"
  if [ "$OS_NAME" = "Darwin" ]; then
    if has networksetup; then
      networksetup -getairportnetwork en0 2>/dev/null || networksetup -getairportnetwork en1 2>/dev/null || true
    fi
  elif has nmcli; then
    nmcli device status || true
    nmcli connection show --active || true
  else
    log "nmcli not installed"
  fi
}

monitor() {
  seconds="${1:-2}"

  if has watch; then
    watch -n "$seconds" "$0 summary"
  else
    while :; do
      clear
      summary
      sleep "$seconds"
    done
  fi
}

export_report() {
  file="${1:-network-report-$(date +%Y%m%d-%H%M%S).txt}"

  {
    printf 'network-tools report\n'
    date
    printf '\nversion: %s\n' "$VERSION"
    summary
    doctor
    vpn
    firewall
  } >"$file"

  log "wrote $file"
}

paths() {
  section "Executable"
  if has nt; then
    command -v nt
  else
    log "nt is not in PATH"
  fi

  section "Config"
  printf '%s\n' "$HOME/.config/network-tools/network-tools.zsh"
  printf '%s\n' "$HOME/.config/network-tools/completions/nt.zsh"

  section "OS"
  printf '%s\n' "$OS_NAME"
}

version() {
  printf 'network-tools %s\n' "$VERSION"
  printf 'os %s\n' "$OS_NAME"
  if has nt; then
    printf 'nt %s\n' "$(command -v nt)"
  fi
}

fix() {
  section "Shell alias"
  if [ -n "${ZSH_VERSION:-}" ] || [ -n "${BASH_VERSION:-}" ]; then
    unalias nt 2>/dev/null || true
    hash -r 2>/dev/null || true
    log "cleared stale nt alias in this shell"
  else
    log "run this in your shell if nt is still aliased: unalias nt 2>/dev/null; hash -r"
  fi

  section "Shell integration"
  integration="$HOME/.config/network-tools/network-tools.zsh"
  if [ -r "$integration" ]; then
    log "found $integration"
    if [ -n "${ZSH_VERSION:-}" ]; then
      # shellcheck disable=SC1090
      . "$integration"
      log "reloaded zsh integration"
    fi
  else
    log "missing $integration"
  fi

  section "Result"
  if has nt; then
    command -v nt
    nt version
  else
    log "nt is not in PATH; add ~/.local/bin to PATH or rerun ./install.sh"
  fi
}

selftest() {
  failures=0

  section "Command"
  if has nt; then
    command -v nt
  else
    log "nt is not in PATH yet; using $0"
  fi

  section "Core commands"
  for cmd in doctor tools path version help; do
    if "$0" "$cmd" >/dev/null 2>&1; then
      printf 'ok      %s\n' "$cmd"
    else
      printf 'failed  %s\n' "$cmd"
      failures=$((failures + 1))
    fi
  done

  section "Shell integration"
  integration="$HOME/.config/network-tools/network-tools.zsh"
  completion="$HOME/.config/network-tools/completions/nt.zsh"
  if [ -r "$integration" ]; then
    printf 'ok      %s\n' "$integration"
  else
    printf 'not installed %s\n' "$integration"
  fi
  if [ -r "$completion" ]; then
    printf 'ok      %s\n' "$completion"
  else
    printf 'not installed %s\n' "$completion"
  fi

  section "Result"
  if [ "$failures" -eq 0 ]; then
    log "selftest ok"
  else
    printf 'selftest failed: %s issue(s)\n' "$failures" >&2
    return 1
  fi
}

scan() {
  target="${1:-}"
  if [ -z "$target" ]; then
    printf 'usage: nt scan <target>\n' >&2
    return 2
  fi

  run_if nmap -T4 --top-ports 100 "$target"
}

capture() {
  iface="${1:-any}"
  file="${2:-capture-$(date +%Y%m%d-%H%M%S).pcap}"

  if ! has tcpdump; then
    printf 'missing command: tcpdump\n' >&2
    return 127
  fi

  printf 'capturing on %s to %s; press Ctrl+C to stop\n' "$iface" "$file"
  tcpdump -i "$iface" -w "$file"
}

vpn() {
  section "Tailscale"
  if has tailscale; then
    tailscale status || true
  else
    log "tailscale not installed"
  fi

  section "WireGuard"
  if has wg; then
    wg show || true
  else
    log "wireguard tools not installed"
  fi

  section "OpenVPN"
  if has systemctl; then
    systemctl --no-pager --type=service --state=running | grep -i openvpn || true
  elif has openvpn; then
    log "openvpn command is installed"
  else
    log "openvpn not installed"
  fi
}

firewall() {
  if [ "$OS_NAME" = "Darwin" ]; then
    section "pf"
    if has pfctl; then
      pfctl -s info 2>/dev/null || true
      pfctl -sr 2>/dev/null || true
    else
      log "pfctl not installed"
    fi
    return 0
  fi

  section "UFW"
  if has ufw; then
    ufw status verbose || true
  else
    log "ufw not installed"
  fi

  section "nftables"
  if has nft; then
    nft list ruleset 2>/dev/null || true
  else
    log "nft not installed"
  fi

  section "iptables"
  if has iptables; then
    iptables -S 2>/dev/null || true
  else
    log "iptables not installed"
  fi
}

speed() {
  if has speedtest; then
    speedtest
  elif has speedtest-cli; then
    speedtest-cli
  else
    printf 'missing command: speedtest or speedtest-cli\n' >&2
    return 127
  fi
}

myip() {
  if has curl; then
    curl -fsS --max-time 5 https://ifconfig.me || warn "public IP lookup failed"
    printf '\n'
  else
    run_if wget -T 5 -qO- https://ifconfig.me
    printf '\n'
  fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  doctor) doctor "$@" ;;
  quick) quick "$@" ;;
  tools) tools "$@" ;;
  summary) summary "$@" ;;
  interfaces|ifaces) interfaces "$@" ;;
  routes|route) routes "$@" ;;
  dns) dns "$@" ;;
  http|headers) http "$@" ;;
  tls|cert) tls "$@" ;;
  whois|rdap) whois_lookup "$@" ;;
  ping) ping_host "$@" ;;
  trace|traceroute) trace_host "$@" ;;
  ports) ports "$@" ;;
  scan) scan "$@" ;;
  capture|cap) capture "$@" ;;
  wifi) wifi "$@" ;;
  monitor|watch) monitor "$@" ;;
  export|report) export_report "$@" ;;
  path|paths) paths "$@" ;;
  fix) fix "$@" ;;
  selftest|test) selftest "$@" ;;
  vpn) vpn "$@" ;;
  firewall|fw) firewall "$@" ;;
  speed) speed "$@" ;;
  myip|ip) myip "$@" ;;
  help|-h|--help) usage ;;
  version|-v|--version) version ;;
  *) usage >&2; exit 2 ;;
esac
